#!/usr/bin/env sh
set -eu

# Claude Code launcher for Horizon's Anthropic-compatible endpoint.
#
# This command intentionally does not replace the native `claude` command.
# It sets Horizon-specific environment variables, loads a saved API key and
# model configuration when present, then delegates to the installed Claude Code binary.

REAL_CLAUDE="${CLAUDE_HORIZON_CLAUDE_BIN:-claude}"
CONFIG_DIR="${CLAUDE_HORIZON_CONFIG_DIR:-$HOME/.config/claude-horizon}"
CONFIG_FILE="${CLAUDE_HORIZON_CONFIG:-$CONFIG_DIR/env}"
MODELS_FILE="${CLAUDE_HORIZON_MODELS_FILE:-$CONFIG_DIR/models}"

# Default: only HORIZON-DeepSeek-Pro is visible in /model.
# Use claude-horizon-models to add more models.
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-https://llmapi.horizon.auto}"
export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-HORIZON-DeepSeek-Pro}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-HORIZON-DeepSeek-Pro}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-HORIZON-GLM}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-HORIZON-DeepSeek-Pro}"
export CLAUDE_CODE_SUBAGENT_MODEL="${CLAUDE_CODE_SUBAGENT_MODEL:-HORIZON-GLM}"
export CLAUDE_CODE_EFFORT_LEVEL="${CLAUDE_CODE_EFFORT_LEVEL:-max}"

# Source user model overrides if present.
if [ -r "$MODELS_FILE" ]; then
  # shellcheck disable=SC1090
  . "$MODELS_FILE"
fi

if [ -r "$CONFIG_FILE" ]; then
  first_line=$(sed -n '1p' "$CONFIG_FILE")
  case "$first_line" in
    export\ *)
      # Backward compatible with env-style config files.
      # shellcheck disable=SC1090
      . "$CONFIG_FILE"
      ;;
    *)
      if [ -n "$first_line" ]; then
        ANTHROPIC_AUTH_TOKEN="$first_line"
        export ANTHROPIC_AUTH_TOKEN
      fi
      ;;
  esac
fi

case " ${*:-} " in
  *" --version "*|*" -v "*|*" --help "*|*" -h "*)
    exec "$REAL_CLAUDE" "$@"
    ;;
esac

if [ -z "${ANTHROPIC_AUTH_TOKEN:-}" ] && [ -n "${DEEPSEEK_API_KEY:-}" ]; then
  ANTHROPIC_AUTH_TOKEN="$DEEPSEEK_API_KEY"
  export ANTHROPIC_AUTH_TOKEN
fi

if [ -z "${ANTHROPIC_AUTH_TOKEN:-}" ]; then
  if [ ! -t 0 ]; then
    echo "No Horizon API key configured. Run: claude-horizon-config" >&2
    exit 2
  fi

  printf 'Horizon API Key: ' >&2
  oldstty=$(stty -g)
  trap 'stty "$oldstty" >/dev/null 2>&1 || true' INT TERM EXIT
  stty -echo
  IFS= read -r ANTHROPIC_AUTH_TOKEN
  stty "$oldstty"
  trap - INT TERM EXIT
  printf '\n' >&2
  export ANTHROPIC_AUTH_TOKEN
fi

exec "$REAL_CLAUDE" "$@"