#!/usr/bin/env sh
set -eu

# Claude Code launcher for DeepSeek's Anthropic-compatible endpoint.
#
# This command intentionally does not replace the native `claude` command.
# It sets DeepSeek-specific environment variables, loads a saved API key when
# present, then delegates to the installed Claude Code binary.

REAL_CLAUDE="${CLAUDE_DEEPSEEK_CLAUDE_BIN:-claude}"
CONFIG_FILE="${CLAUDE_DEEPSEEK_CONFIG:-$HOME/.config/claude-deepseek/env}"

export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-https://api.deepseek.com/anthropic}"
export ANTHROPIC_MODEL="${ANTHROPIC_MODEL:-deepseek-v4-pro[1m]}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-deepseek-v4-pro[1m]}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-deepseek-v4-flash}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-deepseek-v4-flash}"
export CLAUDE_CODE_SUBAGENT_MODEL="${CLAUDE_CODE_SUBAGENT_MODEL:-deepseek-v4-flash}"
export CLAUDE_CODE_EFFORT_LEVEL="${CLAUDE_CODE_EFFORT_LEVEL:-max}"

if [ -r "$CONFIG_FILE" ]; then
  first_line=$(sed -n '1p' "$CONFIG_FILE")
  case "$first_line" in
    export\ *)
      # Backward compatible with env-style config files.
      # shellcheck disable=SC1090
      . "$CONFIG_FILE"
      ;;
    *)
      if [ -n "$first_line" ]; then
        ANTHROPIC_AUTH_TOKEN="$first_line"
        export ANTHROPIC_AUTH_TOKEN
      fi
      ;;
  esac
fi

case " ${*:-} " in
  *" --version "*|*" -v "*|*" --help "*|*" -h "*)
    exec "$REAL_CLAUDE" "$@"
    ;;
esac

if [ -z "${ANTHROPIC_AUTH_TOKEN:-}" ] && [ -n "${DEEPSEEK_API_KEY:-}" ]; then
  ANTHROPIC_AUTH_TOKEN="$DEEPSEEK_API_KEY"
  export ANTHROPIC_AUTH_TOKEN
fi

if [ -z "${ANTHROPIC_AUTH_TOKEN:-}" ]; then
  if [ ! -t 0 ]; then
    echo "No DeepSeek API key configured. Run: claude-deepseek-config" >&2
    exit 2
  fi

  printf 'DeepSeek API Key: ' >&2
  oldstty=$(stty -g)
  trap 'stty "$oldstty" >/dev/null 2>&1 || true' INT TERM EXIT
  stty -echo
  IFS= read -r ANTHROPIC_AUTH_TOKEN
  stty "$oldstty"
  trap - INT TERM EXIT
  printf '\n' >&2
  export ANTHROPIC_AUTH_TOKEN
fi

exec "$REAL_CLAUDE" "$@"
